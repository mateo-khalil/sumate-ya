PORT=4000

# Supabase — obtener desde https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<tu-anon-key>
# Service role key (sólo para operaciones admin que bypasean RLS — NUNCA exponer al cliente)
SUPABASE_SERVICE_KEY=<tu-service-role-key>
