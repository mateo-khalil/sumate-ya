{
  "name": "@sumate-ya/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "docker compose -f docker-compose.yml up -d postgres",
    "db:stop": "docker compose -f docker-compose.yml down",
    "db:migrate": "tsx src/scripts/dbMigrate.ts",
    "db:seed": "tsx src/scripts/dbSeed.ts",
    "supabase": "supabase",
    "supabase:link": "supabase link --project-ref getfqjkfsueucoalvtcc",
    "supabase:new": "supabase migration new",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:diff": "supabase db diff",
    "supabase:list": "supabase migration list",
    "supabase:reset": "supabase db reset --linked",
    "supabase:types": "supabase gen types typescript --linked --schema public > src/generated/supabase.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@graphql-tools/schema": "^10.0.25",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/load-files": "^7.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@types/cors": "^2.8.19",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
