{
  "name": "@sumate-ya/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "codegen": "graphql-codegen --config codegen.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@graphql-tools/merge": "^9.0.18",
    "@graphql-tools/load-files": "^7.0.0",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.6",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-resolvers": "^4.4.4",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
