---
/**
 * Login Page (SSR)
 *
 * Decision Context:
 * - Why SSR: Handles POST form submission server-side and reads/writes auth cookies.
 * - Pattern: Progressive enhancement — works without JS. POST + redirect, no client fetch.
 * - Security: Frontend does not call Supabase directly; credentials are posted to backend auth.
 *   HttpOnly cookies store tokens for subsequent SSR middleware checks.
 * - Previously fixed bugs: none relevant.
 */
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import {
  ACCESS_TOKEN_COOKIE,
  ACCESS_TOKEN_MAX_AGE,
  REFRESH_TOKEN_COOKIE,
  REFRESH_TOKEN_MAX_AGE,
  clearAuthCookies,
  getAuthCookieOptions,
  getRoleRedirect,
  getSessionFromBackend,
  loginWithBackend,
  readAccessToken,
} from '../lib/auth';

const accessToken = readAccessToken(Astro.cookies);

if (accessToken) {
  const user = await getSessionFromBackend(accessToken);
  if (user) {
    return Astro.redirect(getRoleRedirect(user.role));
  }

  clearAuthCookies(Astro.cookies);
}

// --- Mensaje de registro exitoso ---
const registered = Astro.url.searchParams.get('registered') === '1';

// --- Manejo del formulario POST ---
let errorMessage = '';
let emailValue = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  emailValue = formData.get('email')?.toString() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  if (!emailValue || !password) {
    errorMessage = 'Completá todos los campos.';
  } else {
    try {
      const result = await loginWithBackend(emailValue, password);
      const isProd = Astro.url.protocol === 'https:';

      // P3: separate maxAge — short-lived access token, long-lived refresh token.
      Astro.cookies.set(ACCESS_TOKEN_COOKIE, result.accessToken, getAuthCookieOptions(isProd, ACCESS_TOKEN_MAX_AGE));
      Astro.cookies.set(REFRESH_TOKEN_COOKIE, result.refreshToken, getAuthCookieOptions(isProd, REFRESH_TOKEN_MAX_AGE));

      return Astro.redirect(getRoleRedirect(result.user.role));
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Authentication failed';

      if (message.includes('Email not confirmed') || message.includes('email_not_confirmed')) {
        errorMessage =
          'Debés confirmar tu email antes de iniciar sesión. Revisá tu casilla de correo.';
      } else if (
        message.includes('Invalid login credentials') ||
        message.includes('invalid_credentials')
      ) {
        errorMessage = 'Email o contraseña incorrectos.';
      } else {
        errorMessage = 'Ocurrió un error al iniciar sesión. Intentá de nuevo.';
      }
    }
  }
}
---

<Layout title="Iniciar sesión — Sumate Ya">
  <main class="login-wrapper">
    <!-- Stadium arc decoration -->
    <div class="stadium-arc" aria-hidden="true"></div>

    <div class="login-card">
      <div class="login-header">
        <div class="brand-lockup">
          <span class="brand-icon">⚽</span>
          <h1 class="brand-name">SUMATE YA</h1>
        </div>
        <p class="login-subtitle">Iniciá sesión para continuar</p>
      </div>

      {
        registered && (
          <div class="success-banner" role="status">
            <span>✓</span>
            <span>Registro exitoso. Ya podés iniciar sesión.</span>
          </div>
        )
      }

      {
        errorMessage && (
          <div class="error-banner" role="alert">
            <span class="error-icon">⚠</span>
            <span>{errorMessage}</span>
          </div>
        )
      }

      <form method="POST" novalidate class="login-form">
        <div class="field">
          <label for="email">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            value={emailValue}
            autocomplete="email"
            required
            placeholder="tu@email.com"
          />
        </div>

        <div class="field">
          <label for="password">Contraseña</label>
          <input
            id="password"
            type="password"
            name="password"
            autocomplete="current-password"
            required
            placeholder="••••••••"
          />
        </div>

        <button type="submit" class="btn-submit">INGRESAR</button>
      </form>

      <p class="register-link">
        ¿Sos un club? <a href="/registro-club">Registrate acá</a>
      </p>
    </div>
  </main>
</Layout>

<style>
  /* ---- Layout ---- */
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  /* ---- Stadium arc decoration ---- */
  .stadium-arc {
    position: fixed;
    bottom: -30vw;
    left: 50%;
    transform: translateX(-50%);
    width: 90vw;
    height: 45vw;
    border: 2px solid rgba(246, 164, 0, 0.12);
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    pointer-events: none;
  }

  .stadium-arc::before {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 60%;
    border: 1px solid rgba(27, 105, 224, 0.10);
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }

  /* ---- Card (glassmorphism) ---- */
  .login-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 16px;
    padding: 2.75rem 2.25rem;
    width: 100%;
    max-width: 420px;
    box-shadow:
      0 0 0 1px rgba(246, 164, 0, 0.06),
      0 24px 64px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
    position: relative;
    z-index: 1;
  }

  /* Orange top stripe */
  .login-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 2rem;
    right: 2rem;
    height: 3px;
    background: linear-gradient(90deg, hsl(35 100% 48%), hsl(216 85% 45%));
    border-radius: 0 0 3px 3px;
  }

  /* ---- Brand header ---- */
  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .brand-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .brand-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: #ffffff;
    margin: 0;
    line-height: 1;
  }

  .login-subtitle {
    margin: 0;
    color: hsl(215 20% 55%);
    font-size: 0.875rem;
    font-family: 'Barlow', sans-serif;
    letter-spacing: 0.01em;
  }

  /* ---- Error banner ---- */
  .error-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: rgba(220, 38, 38, 0.12);
    border: 1px solid rgba(220, 38, 38, 0.35);
    color: hsl(0 72% 70%);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    font-family: 'Barlow', sans-serif;
  }

  .error-icon {
    flex-shrink: 0;
  }

  /* ---- Form fields ---- */
  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: hsl(215 20% 65%);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: 'Barlow Condensed', sans-serif;
  }

  .field input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: 'Barlow', sans-serif;
    color: hsl(210 20% 94%);
    transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    outline: none;
    width: 100%;
  }

  .field input::placeholder {
    color: hsl(215 20% 40%);
  }

  .field input:focus {
    border-color: hsl(216 85% 55%);
    background: rgba(27, 105, 224, 0.08);
    box-shadow: 0 0 0 3px rgba(27, 105, 224, 0.2);
  }

  /* ---- Submit button ---- */
  .btn-submit {
    margin-top: 0.5rem;
    padding: 0.875rem;
    background: linear-gradient(135deg, hsl(35 100% 48%), hsl(35 100% 42%));
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: transform 0.1s, box-shadow 0.15s, filter 0.15s;
    box-shadow: 0 4px 20px rgba(246, 164, 0, 0.35);
    position: relative;
    overflow: hidden;
  }

  .btn-submit::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(255,255,255,0.1), transparent);
    pointer-events: none;
  }

  .btn-submit:hover {
    filter: brightness(1.08);
    box-shadow: 0 6px 28px rgba(246, 164, 0, 0.5);
    transform: translateY(-1px);
  }

  .btn-submit:active {
    transform: scale(0.98) translateY(0);
    box-shadow: 0 2px 12px rgba(246, 164, 0, 0.3);
  }

  /* ---- Success banner ---- */
  .success-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: hsl(142 70% 60%);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    font-family: 'Barlow', sans-serif;
  }

  /* ---- Register link ---- */
  .register-link {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.875rem;
    font-family: 'Barlow', sans-serif;
    color: hsl(215 20% 50%);
  }

  .register-link a {
    color: hsl(35 100% 55%);
    text-decoration: none;
    font-weight: 600;
  }

  .register-link a:hover {
    text-decoration: underline;
  }
</style>
