---
/**
 * Login Page (SSR)
 *
 * Decision Context:
 * - Why SSR: Handles POST form submission server-side and reads/writes auth cookies.
 * - Pattern: Progressive enhancement — works without JS. POST + redirect, no client fetch.
 * - Security: Uses getUser() (validates JWT server-side) instead of getSession().
 *   Error messages are ambiguous to avoid revealing email existence.
 * - Previously fixed bugs: none relevant.
 */
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { createSupabaseServerClient, getRoleRedirect, type UserRole } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

// Si ya tiene sesión activa, redirigir según rol
const {
  data: { user },
} = await supabase.auth.getUser();

if (user) {
  const { data: profile } = await supabase
    .from('profiles')
    .select('role')
    .eq('id', user.id)
    .single();
  return Astro.redirect(getRoleRedirect(profile?.role as UserRole | undefined));
}

// --- Manejo del formulario POST ---
let errorMessage = '';
let emailValue = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  emailValue = formData.get('email')?.toString() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  if (!emailValue || !password) {
    errorMessage = 'Completá todos los campos.';
  } else {
    const { data, error } = await supabase.auth.signInWithPassword({
      email: emailValue,
      password,
    });

    if (error) {
      // Supabase devuelve distintos mensajes según el tipo de error
      if (
        error.message.includes('Email not confirmed') ||
        error.message.includes('email_not_confirmed')
      ) {
        errorMessage =
          'Debés confirmar tu email antes de iniciar sesión. Revisá tu casilla de correo.';
      } else if (
        error.message.includes('Invalid login credentials') ||
        error.message.includes('invalid_credentials')
      ) {
        errorMessage = 'Email o contraseña incorrectos.';
      } else {
        errorMessage = 'Ocurrió un error al iniciar sesión. Intentá de nuevo.';
      }
    } else if (data.session) {
      const { data: profile } = await supabase
        .from('profiles')
        .select('role')
        .eq('id', data.user.id)
        .single();
      return Astro.redirect(getRoleRedirect(profile?.role as UserRole | undefined));
    }
  }
}
---

<Layout title="Iniciar sesión">
  <main class="login-wrapper">
    <div class="login-card">
      <div class="login-header">
        <span class="login-logo">⚽</span>
        <h1>Sumate Ya</h1>
        <p class="login-subtitle">Iniciá sesión para continuar</p>
      </div>

      {
        errorMessage && (
          <div class="error-banner" role="alert">
            <span class="error-icon">⚠</span>
            {errorMessage}
          </div>
        )
      }

      <form method="POST" novalidate class="login-form">
        <div class="field">
          <label for="email">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            value={emailValue}
            autocomplete="email"
            required
            placeholder="tu@email.com"
          />
        </div>

        <div class="field">
          <label for="password">Contraseña</label>
          <input
            id="password"
            type="password"
            name="password"
            autocomplete="current-password"
            required
            placeholder="••••••••"
          />
        </div>

        <button type="submit" class="btn-submit">Ingresar</button>
      </form>
    </div>
  </main>
</Layout>

<style>
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
  }

  .login-card {
    background: #fff;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .login-header {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .login-logo {
    font-size: 2.5rem;
  }

  .login-header h1 {
    margin: 0.25rem 0 0.25rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f172a;
  }

  .login-subtitle {
    margin: 0;
    color: #64748b;
    font-size: 0.9rem;
  }

  .error-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #b91c1c;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .error-icon {
    flex-shrink: 0;
    font-style: normal;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
  }

  .field input {
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 0.625rem 0.875rem;
    font-size: 1rem;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    width: 100%;
  }

  .field input:focus {
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .btn-submit {
    margin-top: 0.5rem;
    padding: 0.75rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }

  .btn-submit:hover {
    background: #1d4ed8;
  }

  .btn-submit:active {
    transform: scale(0.98);
  }
</style>
