    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.upload-placeholder) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: hsl(215 20% 50%);
  }
