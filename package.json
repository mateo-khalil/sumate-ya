{
  "name": "sumate-ya",
  "version": "0.1.0",
  "private": true,
  "description": "Sumate Ya - Football player connection platform monorepo",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "sumate-ya": "ln -sfn ../../.env apps/backend/.env && echo 'Symlinked root .env into apps/backend/.env. Frontend keeps its own optional apps/frontend/.env'",
    "dev": "turbo dev",
    "dev:frontend": "turbo dev --filter=@sumate-ya/frontend",
    "dev:backend": "turbo dev --filter=@sumate-ya/backend",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck --force",
    "test": "turbo test",
    "codegen": "turbo codegen",
    "format": "turbo format",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "devDependencies": {
    "supabase": "^2.89.1",
    "turbo": "^2.8.20"
  }
}
